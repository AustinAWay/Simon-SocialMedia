{
  "name": "simon-socialmedia",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Script -> fully edited vertical Simon explainer video (+ title & description) for YouTube Shorts / TikTok / Reels. All AI generation runs through the Higgsfield CLI.",
